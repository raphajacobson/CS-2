import random
import time

def build_board():
#make 3x3 empty board and print it
    board = [[' 1 ', ' 2 ', ' 3 '],                     #build a 3x3 board with numbers as placeholders for each coordinate
             [' 4 ', ' 5 ', ' 6 '],
             [' 7 ', ' 8 ', ' 9 ']
    ]
    for row in board:                                   #for loop which prints a board in 2D form
        for cell in row:
            print(cell, end=' ')                        
        print()

def show_board(board):                                  #function that prints the board (even when positions change from the placholder numbers to "X" or "O")
    for row in board:
        for cell in row:
            print(cell, end=' ')
        print()

def players_move(board, player):                        #function which defines the players move based on their input (a number that is still on the board)
    while True:
        placement = input(f"Player {player}: enter the number where you would like to move: ")      #player input of a number on where they would like to move 
        #this if condition takes in the user's input on where they would like to move, checks to make sure the spot is already taken, re-prompts them if it is, and if it is not already taken, replaces the spot with either X or O (depending on which player they are)
        if placement == "1":                                                                        
            if board[0][0] == " O " or board[0][0] == " X ":                                        #check to make sure spot is not already occupied
                print("That spot is already taken - try again")
            else:   
                board[0][0] = player                                                                #change the placholder number into X or O (depending on which the player is)
                break   
        elif placement == "2":
            if board[0][1] == " O " or board[0][1] == " X ":                                        
                print("That spot is already taken - try again")
            else:
                board[0][1] = player                                                                
                break
        elif placement == "3":
            if board[0][2] == " O " or board[0][2] == " X ":                                        
                print("That spot is already taken - try again")
            else:
                board[0][2] = player                                                              
                break
        elif placement == "4":
            if board[1][0] == " O " or board[1][0] == " X ":                                        
                print("That spot is already taken - try again")
            else:
                board[1][0] = player                                                                
                break   
        elif placement == "5":
            if board[1][1] == " O " or board[1][1] == " X ":                                        
                print("That spot is already taken - try again")
            else:
                board[1][1] = player                                                                
                break
        elif placement == "6":
            if board[1][2] == " O " or board[1][2] == " X ":                                        
                print("That spot is already taken - try again")
            else:
                board[1][2] = player                                                                
                break
        elif placement == "7":
            if board[2][0] == " O " or board[2][0] == " X ":                                        
                print("That spot is already taken - try again")
            else:
                board[2][0] = player                                                                
                break
        elif placement == "8":
            if board[2][1] == " O " or board[2][1] == " X ":                                        
                print("That spot is already taken - try again")
            else:
                board[2][1] = player                                                                
                break
        elif placement == "9":
            if board[2][2] == " O " or board[2][2] == " X ":                                        
                print("That spot is already taken - try again")
            else:
                board[2][2] = player                                                                
                break
        else:
            print("Invalid input - Try again")                                                      #make sure user's input is valid and if not, redicrect them to re-enter through the while True loop

    show_board(board)

def comps_move(board, player):         
    #function which defines the computer's move
    print("The computer will now move: " \
    "")
    #times = 0
    while True:
        row = random.randint(0, 2)                                                                  #choose a random row coordinate
        col = random.randint(0, 2)                                                                  #choose a random column coordinate
        #times +=1
        if board[row][col] == " X " or board[row][col] == " O ":                                    #make sure the coordinate which is randomly picked is not already occupied
            row = random.randint(0, 2)                                                              #re-pick a random row
            col = random.randint(0, 2)                                                              #re-pick a random column
            #times = 0
        else:
            break                                                                                   #continue if the coordinate chosen is not already occupied
            
    board[row][col] = player                                                                        #re-define the coordinate as X or O (depending on what the computer is)
    time.sleep(1)
    show_board(board)                                                                               #show the board



def check_winner(board, player):                                                                    #function which checks if someone has one the game
    #this if condition checks if any three in a row combination has been met and if so, prints that that player (either X or O) has won the game and then ends the game
    if board[0][0] == player and board[0][1] == player and board[0][2] == player:                   #if there are three in a row of "X" or "O"
        print(f"Player {player} has won the game.")                                                 #print that that player (X or O) has one the game
        play_again()                                                                                   #end the game
    elif board[1][0] == player and board[1][1] == player and board[1][2] == player:                 
        print(f"Player {player} has won the game.")                                                 
        play_again()                                                                                  
    elif board[2][0] == player and board[2][1] == player and board[2][2] == player:                
        print(f"Player {player} has won the game.")                                               
        play_again()                                                                             
    elif board[0][0] == player and board[1][0] == player and board[2][0] == player:              
        print(f"Player {player} has won the game.")                                                
        play_again()                                                                            
    elif board[0][1] == player and board[1][1] == player and board[2][1] == player:                
        print(f"Player {player} has won the game.")                                                
        play_again()                                                                         
    elif board[0][2] == player and board[1][2] == player and board[2][2] == player:                 
        print(f"Player {player} has won the game.")                                              
        play_again()                                                                                
    elif board[0][0] == player and board[1][1] == player and board[2][2] == player:              
        print(f"Player {player} has won the game.")                                              
        play_again()                                                                                  
    elif board[0][2] == player and board[1][1] == player and board[2][0] == player:                
        print(f"Player {player} has won the game.")                                              
        play_again()                                                                                   

def play_again():
    #function which is used to ask if player wants to play again after any outcome (tie, win, or loss) and responds accordingly
    while True:
        again = input("Would you like to play again? press 'q' to quit or 'p' to play again: ")     
        if again == 'p':       
            play_game()
        elif again == 'q':
            exit()
        else:
            print("Invalid input - try again")

def play_game():
    #function which executes the game's function with either 2 users or a computer and a user
    while True:
        board = [[' 1 ', ' 2 ', ' 3 '],                                                             #re-define 3x3 board
                [' 4 ', ' 5 ', ' 6 '],
                [' 7 ', ' 8 ', ' 9 ']
        ]
        show_board(board)

        first_options = [" X ", " O "]                                 #define variable firt_options as a list of either X or O
        first = random.choice(first_options)                           #choose either X or O at a random and define it as the variable first
        game = input("Would you like to play with 2 players or with a computer? Enter '2' or 'c': ")    #ask the user if they want to play with 2 players or with a computer
        if game == "2":                                 #if user chooses 2 player game
            if first == " X ":                          #if player X is going first
                print("Decide among yourselves who will be X and who will be O. Player X will go first")
                tries = 0                               #set tries to 0
                while tries < 9:                        #while still less than 9 tries
                    players_move(board, " X ")          #run player move function for X
                    check_winner(board, " X ")          #check if X has won
                    tries += 1                          #add 1 to tries list
                    if tries == 9:                      #if tries is equal to 9 (and no one has won yet)
                        print("The game ended as a tie")            #print that the game has ended in a tie
                        play_again()
                    players_move(board, " O ")          #player move function with O
                    check_winner(board, " O ")          #check if O has won
                    tries += 1                  
                    if tries == 9:  
                        print("The game ended as a tie")
                        play_again()
            else:                                      #if player O is going first
                print("Decide among yourselves who will be X and who will be O. Player O will go first")
                tries = 0
                while tries < 9:
                    players_move(board, " O ")         #player move function is run for player O
                    check_winner(board, " O ")         #check if O has won
                    tries += 1  
                    if tries == 9:
                        print("The game ended as a tie")
                        play_again()
                    players_move(board, " X ")         #player move function is run for player X
                    check_winner(board, " X ")         #check if X has won
                    tries += 1
                    if tries == 9:
                        print("The game has ended in a tie")
        elif game == "c" or game == "C":                #if user wants to play against a computer
            comp_options = [" X ", " O "]
            comps_assignment = random.choice(comp_options)
            who = ["the computer", "you"]               #variable "who" is defined by a list of either "the computer" or "you"
            whogoes = random.choice(who)                #variable "whogoes" is defined by a random choice of either "the computer" or "you"
            if comps_assignment == " X ":                #if the computer is X
                print(f"The computer will be {comps_assignment} and {whogoes} will go first")
                if whogoes == "you":                    #if you are going first
                    for row in board:
                        for cell in row:
                            print(cell, end=' ')
                        print()
                    tries = 0
                    while tries < 9:
                        players_move(board, " O ")              #player move function is run for player O
                        check_winner(board, " O ")              #check if O has won
                        tries += 1
                        if tries == 9:
                            print("The game ended as a tie")
                            play_again()
                        comps_move(board, " X ")            #computer moves function is run with "X" as paramater instead of "player"
                        check_winner(board, " X ")          #check if X (computer) has won
                        tries += 1
                        if tries == 9:  
                            print("The game ended as a tie")
                            play_again()
                else:                                   #if the computer is going first
                    tries = 0
                    while tries < 9:
                        comps_move(board, " X ")         #computer moves function is run with "X" as paramater instead of "player"
                        check_winner(board, " X ")       #check if X has won
                        tries += 1
                        if tries == 9:
                            print("The game ended as a tie")
                            play_again()
                        players_move(board, " O ")                      #player move function is run for player O
                        check_winner(board, " O ")                      #check if O has won
                        tries += 1
                        if tries == 9:  
                            print("The game ended as a tie")
                            play_again()
            if comps_assignment == " O ":            #if the computer is O
                who = ["the computer", "you"]
                whogoes = random.choice(who)
                print(f"The computer will be {comps_assignment} and {whogoes} will go first")
                if whogoes == "you":                #if you are going first
                    for row in board:
                        for cell in row:
                            print(cell, end=' ')
                        print()
                    tries = 0
                    while tries < 9:
                        players_move(board, " X ")                      #player move function is run for player X
                        check_winner(board, " X ")                      #check if X has won
                        tries += 1
                        if tries == 9:
                            print("The game ended as a tie")
                            play_again()
                        comps_move(board, " O ")                #computer moves function is run with "O" as paramater instead of "player"
                        check_winner(board, " O ")              #check if O (computer) has won
                        tries += 1
                        if tries == 9:  
                            print("The game ended as a tie")
                            play_again()
                else:                           #if the computer is going first
                    tries = 0
                    while tries < 9:
                        comps_move(board, " O ")            #computer moves function is run with "O" as paramater instead of "player"
                        check_winner(board, " O ")          #check if O (computer) has won
                        tries += 1
                        if tries == 9:
                            print("The game ended as a tie")
                            play_again()
                        players_move(board, " X ")          #player move function is run for player X
                        check_winner(board, " X ")          #check if X has won
